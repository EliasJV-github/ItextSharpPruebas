<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ReputaBank · Gestión de Fuentes y Colaboradores</title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>

  <style>
    :root {
      --navy:    #0b1f3a;
      --navy2:   #132c52;
      --gold:    #c9a84c;
      --gold-lt: #e8c96e;
      --danger:  #c0392b;
      --warn:    #d68910;
      --ok:      #1a7a4a;
      --surface: #f5f6f8;
      --border:  #dde2ea;
      --text:    #1c2535;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background-color: var(--surface);
      color: var(--text);
    }

    /* ── Sidebar ── */
    #sidebar {
      width: 240px;
      min-height: 100vh;
      background: var(--navy);
      position: fixed;
      top: 0; left: 0;
      z-index: 100;
      display: flex;
      flex-direction: column;
    }
    .sidebar-brand {
      font-family: 'DM Serif Display', serif;
      font-size: 1.25rem;
      color: var(--gold);
      padding: 1.5rem 1.25rem 1rem;
      border-bottom: 1px solid rgba(255,255,255,.08);
      letter-spacing: .02em;
    }
    .sidebar-brand small { color: rgba(255,255,255,.45); font-size:.68rem; display:block; font-family:'DM Sans',sans-serif; font-weight:300; letter-spacing:.04em; }
    .sidebar-nav { padding: .75rem 0; flex: 1; }
    .sidebar-nav .nav-link {
      color: rgba(255,255,255,.6);
      font-size: .83rem;
      font-weight: 500;
      padding: .55rem 1.25rem;
      border-radius: 0;
      display: flex; align-items: center; gap:.65rem;
      transition: background .15s, color .15s;
    }
    .sidebar-nav .nav-link:hover,
    .sidebar-nav .nav-link.active {
      background: rgba(201,168,76,.12);
      color: var(--gold-lt);
    }
    .sidebar-nav .nav-link i { font-size: 1rem; }
    .sidebar-section {
      font-size: .65rem; font-weight: 600; letter-spacing: .1em;
      color: rgba(255,255,255,.25); padding: 1.1rem 1.25rem .3rem;
      text-transform: uppercase;
    }
    .sidebar-footer {
      padding: 1rem 1.25rem;
      border-top: 1px solid rgba(255,255,255,.08);
      font-size: .75rem;
      color: rgba(255,255,255,.3);
    }

    /* ── Main ── */
    #main { margin-left: 240px; padding: 2rem 2rem 3rem; }

    /* ── Topbar ── */
    .topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; }
    .topbar-title { font-family: 'DM Serif Display', serif; font-size: 1.6rem; color: var(--navy); line-height: 1.15; }
    .topbar-title small { font-family: 'DM Sans', sans-serif; font-size: .78rem; font-weight:400; color:#6c7a8d; display:block; margin-top:.15rem; }

    /* ── KPI Cards ── */
    .kpi-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      position: relative;
      overflow: hidden;
    }
    .kpi-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; width: 4px; height: 100%;
      background: var(--accent, var(--gold));
      border-radius: 12px 0 0 12px;
    }
    .kpi-card .kpi-icon { font-size: 1.6rem; }
    .kpi-card .kpi-value { font-family: 'DM Serif Display', serif; font-size: 2rem; color: var(--navy); line-height: 1; }
    .kpi-card .kpi-label { font-size: .75rem; color: #6c7a8d; font-weight: 500; text-transform: uppercase; letter-spacing: .06em; }

    /* ── Score Badge ── */
    .score-badge {
      display: inline-flex; align-items: center; justify-content: center;
      width: 42px; height: 42px; border-radius: 50%;
      font-weight: 700; font-size: .85rem; flex-shrink: 0;
    }
    .score-critical { background: #fdecea; color: var(--danger); }
    .score-warn     { background: #fef5e4; color: var(--warn); }
    .score-ok       { background: #e8f8f0; color: var(--ok); }
    .score-neutral  { background: #eef0f4; color: #5a6477; }

    /* ── Risk Pill ── */
    .risk-pill {
      font-size: .68rem; font-weight: 600; letter-spacing: .06em;
      padding: .2rem .55rem; border-radius: 20px; text-transform: uppercase;
    }
    .risk-alto    { background: #fdecea; color: var(--danger); }
    .risk-medio   { background: #fef5e4; color: var(--warn); }
    .risk-bajo    { background: #e8f8f0; color: var(--ok); }
    .risk-neutro  { background: #eef0f4; color: #5a6477; }

    /* ── Table card ── */
    .card-table {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
    }
    .card-table .card-header-custom {
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      background: #fff;
    }
    .card-table .card-header-custom h6 {
      font-family: 'DM Serif Display', serif;
      font-size: 1rem; margin: 0; color: var(--navy);
    }
    .table { margin: 0; font-size: .83rem; }
    .table thead th {
      background: var(--surface);
      color: #6c7a8d;
      font-size: .68rem; font-weight: 600; letter-spacing: .07em;
      text-transform: uppercase;
      border-bottom: 1px solid var(--border);
      padding: .75rem 1rem;
    }
    .table tbody td { padding: .85rem 1rem; vertical-align: middle; border-color: var(--border); }
    .table tbody tr:last-child td { border-bottom: none; }
    .table tbody tr:hover td { background: #fafbfc; }

    .collab-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: var(--navy2); color: var(--gold);
      display: inline-flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: .78rem; flex-shrink: 0;
    }
    .collab-name { font-weight: 600; color: var(--navy); font-size: .85rem; }
    .collab-role { font-size: .73rem; color: #8a96a7; }

    /* source-tag */
    .source-tag {
      display: inline-block; font-size: .65rem; font-weight: 600;
      padding: .15rem .45rem; border-radius: 6px; margin: 1px;
      background: #eef0f4; color: #4a5568;
    }
    .source-tag.neg { background: #fdecea; color: var(--danger); }

    /* Progress mini */
    .score-bar { height: 5px; border-radius: 3px; background: var(--border); overflow: hidden; margin-top: 4px; }
    .score-bar-fill { height: 100%; border-radius: 3px; transition: width .4s; }

    /* ── Fuentes panel ── */
    .source-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1rem 1.25rem;
      height: 100%;
    }
    .source-card .source-icon { font-size: 1.4rem; }
    .source-card .source-name { font-weight: 600; font-size: .88rem; color: var(--navy); }
    .source-card .source-meta { font-size: .72rem; color: #8a96a7; }
    .source-status { font-size: .65rem; font-weight: 600; letter-spacing: .06em; padding: .15rem .5rem; border-radius: 20px; }
    .source-active   { background: #e8f8f0; color: var(--ok); }
    .source-inactive { background: #eef0f4; color: #8a96a7; }

    /* ── Modal tweaks ── */
    .modal-header { background: var(--navy); color: #fff; border-radius: 12px 12px 0 0; }
    .modal-title  { font-family: 'DM Serif Display', serif; }
    .modal-header .btn-close { filter: invert(1) brightness(2); }
    .modal-content { border-radius: 12px; border: none; box-shadow: 0 20px 60px rgba(0,0,0,.2); }

    /* ── Noticias drawer ── */
    .news-item {
      border-left: 3px solid var(--border);
      padding: .5rem .75rem;
      margin-bottom: .5rem;
      font-size: .8rem;
      background: var(--surface);
      border-radius: 0 6px 6px 0;
    }
    .news-item.neg { border-left-color: var(--danger); background: #fdf5f5; }
    .news-item .news-source { font-size: .65rem; color: #8a96a7; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }
    .news-item .news-title  { color: var(--navy); font-weight: 500; line-height: 1.35; }
    .news-item .news-date   { font-size: .63rem; color: #aab4c0; }

    /* Tooltip custom */
    [data-bs-toggle="tooltip"] { cursor: help; }

    /* Responsive */
    @media (max-width: 768px) {
      #sidebar { display: none; }
      #main { margin-left: 0; padding: 1rem; }
    }
  </style>
</head>
